# ─── Agent Wallet ─────────────────────────────────────────────────
# Private key of the agent's CKB wallet (hex, testnet).
# If omitted, a new wallet is generated and saved to the keystore.
AGENT_PRIVATE_KEY=

# ─── CKB Network ─────────────────────────────────────────────────
CKB_RPC_URL=https://testnet.ckb.dev/

# ─── Game Configuration ──────────────────────────────────────────
# Address where entry fees are sent (game treasury / house wallet)
GAME_ADDRESS=

# ─── Backend API ──────────────────────────────────────────────────
# Base URL of the CKB Arcade backend (for payouts and stats)
API_BASE=http://localhost:8787

# Optional API key for payout authentication
PAYOUT_API_KEY=

# ─── Agent Strategy ──────────────────────────────────────────────
# "aggressive" or "conservative"
AGENT_STRATEGY=conservative

# Entry fee per round in CKB
BET_AMOUNT=100

# Initial balance in CKB (for P&L tracking, not actual funding)
INITIAL_BALANCE=1000

# Profit target as decimal (0.20 = 20%)
PROFIT_TARGET=0.20

# Stop loss as decimal (0.15 = 15%)
STOP_LOSS=0.15

# Loop interval in milliseconds
INTERVAL_MS=10000

# ─── Spending Constraints ────────────────────────────────────────
# Maximum CKB per single game entry (0 = unlimited)
MAX_SPEND_PER_GAME=500

# Stop all transactions if on-chain balance drops below this (CKB)
MIN_BALANCE_THRESHOLD=61

# Maximum total CKB spend across the entire session (0 = unlimited)
MAX_SESSION_SPEND=5000
